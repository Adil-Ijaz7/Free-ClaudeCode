# =====================================================
# Free Claude Code — OpenRouter Configuration
# =====================================================

# Get your API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# Optional proxy for OpenRouter requests
OPENROUTER_PROXY=""


# =====================================================
# Model Routing
# =====================================================
# Browse models at: https://openrouter.ai/models
# Format: open_router/<provider>/<model-name>
#
# Popular models:
#   open_router/anthropic/claude-sonnet-4-20250514    (Claude Sonnet 4)
#   open_router/anthropic/claude-3.5-sonnet           (Claude 3.5 Sonnet)
#   open_router/google/gemini-2.5-pro-preview         (Gemini 2.5 Pro)
#   open_router/deepseek/deepseek-r1                  (DeepSeek R1)
#   open_router/meta-llama/llama-4-maverick           (Llama 4 Maverick)
#   open_router/openai/gpt-4.1                        (GPT-4.1)

MODEL="open_router/anthropic/claude-sonnet-4-20250514"

# Optional per-tier overrides (blank = use MODEL for all)
MODEL_OPUS=
MODEL_SONNET=
MODEL_HAIKU=


# =====================================================
# Thinking / Reasoning Output
# =====================================================
ENABLE_MODEL_THINKING=true
ENABLE_OPUS_THINKING=
ENABLE_SONNET_THINKING=
ENABLE_HAIKU_THINKING=


# =====================================================
# Server
# =====================================================
HOST=127.0.0.1
PORT=8082

# Protects Claude Code / API access (not the admin page)
ANTHROPIC_AUTH_TOKEN="freecc"

# Open /admin in browser when server starts (set false to disable)
FCC_OPEN_BROWSER=true


# =====================================================
# Rate Limiting & Timeouts
# =====================================================
PROVIDER_RATE_LIMIT=1
PROVIDER_RATE_WINDOW=3
PROVIDER_MAX_CONCURRENCY=5

HTTP_READ_TIMEOUT=300
HTTP_WRITE_TIMEOUT=60
HTTP_CONNECT_TIMEOUT=60


# =====================================================
# Messaging Platform (CLI-only = "none")
# =====================================================
MESSAGING_PLATFORM="none"
MESSAGING_RATE_LIMIT=1
MESSAGING_RATE_WINDOW=1


# =====================================================
# Voice (disabled by default)
# =====================================================
VOICE_NOTE_ENABLED=false
WHISPER_DEVICE="cpu"
WHISPER_MODEL="base"
HF_TOKEN=""


# =====================================================
# Telegram (optional)
# =====================================================
TELEGRAM_BOT_TOKEN=""
ALLOWED_TELEGRAM_USER_ID=""


# =====================================================
# Discord (optional)
# =====================================================
DISCORD_BOT_TOKEN=""
ALLOWED_DISCORD_CHANNELS=""


# =====================================================
# Agent Optimizations
# =====================================================
ALLOWED_DIR=""
FAST_PREFIX_DETECTION=true
ENABLE_NETWORK_PROBE_MOCK=true
ENABLE_TITLE_GENERATION_SKIP=true
ENABLE_SUGGESTION_MODE_SKIP=true
ENABLE_FILEPATH_EXTRACTION_MOCK=true


# =====================================================
# Web Tools (outbound HTTP from proxy)
# =====================================================
ENABLE_WEB_SERVER_TOOLS=true
WEB_FETCH_ALLOWED_SCHEMES=http,https
WEB_FETCH_ALLOW_PRIVATE_NETWORKS=false


# =====================================================
# Diagnostics (keep false in production)
# =====================================================
DEBUG_PLATFORM_EDITS=false
DEBUG_SUBAGENT_STACK=false
LOG_RAW_API_PAYLOADS=false
LOG_RAW_SSE_EVENTS=false
LOG_API_ERROR_TRACEBACKS=false
LOG_RAW_MESSAGING_CONTENT=false
LOG_RAW_CLI_DIAGNOSTICS=false
LOG_MESSAGING_ERROR_DETAILS=false
